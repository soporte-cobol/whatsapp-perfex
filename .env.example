# Configuración de WhatsApp (Cobol)
WHATSAPP_API_SECRET=tu_secret_aqui
WHATSAPP_ACCOUNT_ID=tu_account_id
WHATSAPP_API_BASE_URL=https://uno.cobol.com.co/api
ADMIN_WHATSAPP_NUMBER=573000000000

# URL Pública de este Webhook (donde se despliega la App Node.js)
WEBHOOK_URL=https://tu-dominio-webhook.com

# API Key para proteger tu Webhook (Úsala en el panel de Cobol como Header X-API-KEY)
WEBHOOK_API_KEY=genera_un_token_seguro_aqui

# Configuración de Perfex CRM
PERFEX_BASE_URL=https://tu-dominio-crm.com
PERFEX_API_TOKEN=tu_token_seguro_con_el_bridge_php

PORT=3000